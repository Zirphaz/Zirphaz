DISCORD_TOKEN=cole_o_token_do_bot_aqui
CLIENT_ID=id_do_aplicativo_bot
GUILD_ID=id_do_servidor

# Cargo da equipe de atendimento que pode gerenciar tickets
SUPPORT_ROLE_ID=id_do_cargo_de_suporte

# Categoria principal onde os tickets serao criados
TICKET_CATEGORY_ID=id_da_categoria_de_tickets

# Categorias permitidas para transferir tickets.
# Formato: ID:NOME,ID:NOME
TRANSFER_CATEGORY_IDS=123456789012345678:Tickets - Suporte,234567890123456789:Tickets - Doacoes,345678901234567890:Tickets - Bug,456789012345678901:Tickets - Denuncia,567890123456789012:Tickets - Fale Owner,678901234567890123:Tickets - Auxilio Lore

# Opcional: categorias especificas para cada tipo de ticket
TICKET_TYPE_CATEGORY_IDS=123456789012345678:suporte,234567890123456789:doacoes,345678901234567890:bug,456789012345678901:denuncia,567890123456789012:fale_owner,678901234567890123:auxilio_lore

# Opcional: canal para logs de tickets fechados
LOG_CHANNEL_ID=

# Opcional: logs separados por categoria e log geral privado do dono
TICKET_LOG_CHANNEL_IDS=123456789012345678:suporte,234567890123456789:doacoes,345678901234567890:bug,456789012345678901:denuncia,567890123456789012:fale_owner,678901234567890123:auxilio_lore
OWNER_LOG_CHANNEL_ID=

# Opcional: prefixo dos canais de ticket
TICKET_PREFIX=ticket
